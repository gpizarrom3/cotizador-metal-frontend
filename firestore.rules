rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Subcollections del usuario: dueño con acceso completo
    match /usuarios/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Documento raíz del usuario: dueño completo + lectores pueden gestionar su propia entrada en sharedReaders
    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        request.auth.uid != userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sharedReaders']) &&
        request.resource.data.get('sharedReaders', {}).diff(resource.data.get('sharedReaders', {})).affectedKeys().hasOnly([request.auth.uid]) &&
        (
          (request.auth.uid in request.resource.data.get('sharedReaders', {}) &&
           exists(/databases/$(database)/documents/aceptaciones/$(userId + '_' + request.auth.uid))) ||
          !(request.auth.uid in request.resource.data.get('sharedReaders', {}))
        );
      allow create: if request.auth != null &&
        request.auth.uid != userId &&
        request.resource.data.keys().hasOnly(['sharedReaders']) &&
        request.resource.data.sharedReaders.keys().hasOnly([request.auth.uid]) &&
        exists(/databases/$(database)/documents/aceptaciones/$(userId + '_' + request.auth.uid));
    }

    // Cotizaciones: dueño cubierto por {document=**}; lectores con entrada en sharedReaders del doc raíz
    match /usuarios/{userId}/cotizaciones/{cotId} {
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/usuarios/$(userId)).data.get('sharedReaders', {});
      allow create, update: if request.auth != null && esEditor(userId);
    }

    function esEditor(userId) {
      return get(/databases/$(database)/documents/usuarios/$(userId)).data.get('sharedReaders', {})[request.auth.uid] == 'editor';
    }

    // sharedWith: se mantiene por compatibilidad con reglas anteriores
    match /usuarios/{userId}/sharedWith/{readerUid} {
      allow create: if request.auth != null && request.auth.uid == readerUid;
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.uid == readerUid);
      allow delete: if request.auth != null &&
        (request.auth.uid == userId || request.auth.uid == readerUid);
    }

    // Invitaciones: el emisor crea, ambos pueden leer, el receptor actualiza estado
    match /invitaciones/{invId} {
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toEmail == request.auth.token.email
      );
      allow update: if request.auth != null &&
        resource.data.toEmail == request.auth.token.email;
      allow delete: if request.auth != null &&
        resource.data.fromUid == request.auth.uid;
    }

    // Aceptaciones: el receptor crea; ambos pueden leer y eliminar
    match /aceptaciones/{conexionId} {
      allow create: if request.auth != null &&
        request.resource.data.readerUid == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.readerUid == request.auth.uid
      );
      allow delete: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.readerUid == request.auth.uid
      );
    }

    // Espacio compartido dominio innovattech.org
    match /empresas/{empresa}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
