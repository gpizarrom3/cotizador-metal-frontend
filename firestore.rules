rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cada usuario accede a sus propios datos
    match /usuarios/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Cotizaciones compartidas: el lector puede leer si tiene entrada en sharedWith del dueño
    match /usuarios/{userId}/cotizaciones/{cotId} {
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/usuarios/$(userId)/sharedWith/$(request.auth.uid));
      allow create, update: if request.auth != null && esEditor(userId);
    }

    // Índice de acceso: dentro de la misma jerarquía del dueño (necesario para que Firestore
    // pueda evaluar exists() en reglas de queries de colección)
    match /usuarios/{userId}/sharedWith/{readerUid} {
      allow create: if request.auth != null && request.auth.uid == readerUid;
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.uid == readerUid);
      allow delete: if request.auth != null &&
        (request.auth.uid == userId || request.auth.uid == readerUid);
    }

    function esEditor(userId) {
      return exists(/databases/$(database)/documents/usuarios/$(userId)/sharedWith/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(userId)/sharedWith/$(request.auth.uid)).data.permiso == 'editor';
    }

    // Invitaciones: el emisor crea, ambos pueden leer, el receptor actualiza estado
    match /invitaciones/{invId} {
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toEmail == request.auth.token.email
      );
      allow update: if request.auth != null &&
        resource.data.toEmail == request.auth.token.email;
      allow delete: if request.auth != null &&
        resource.data.fromUid == request.auth.uid;
    }

    // Aceptaciones: el receptor crea; ambos pueden leer y eliminar
    match /aceptaciones/{conexionId} {
      allow create: if request.auth != null &&
        request.resource.data.readerUid == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.readerUid == request.auth.uid
      );
      allow delete: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.readerUid == request.auth.uid
      );
    }

    // Espacio compartido dominio innovattech.org
    match /empresas/{empresa}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
